
{
  "entities": {
    "SecureMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SecureMessage",
      "type": "object",
      "description": "Represents a piece of secure content or output to be displayed on a restricted page, typically visible only after successful authentication.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "displayOrder": { "type": "number" }
      },
      "required": ["id", "title", "content", "createdAt"]
    },
    "SecurePageAccessLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SecurePageAccessLog",
      "type": "object",
      "description": "Records attempts to access the secure messaging output page.",
      "properties": {
        "id": { "type": "string" },
        "accessedAt": { "type": "string", "format": "date-time" },
        "username": { "type": "string" },
        "accessSuccessful": { "type": "boolean" },
        "ipAddress": { "type": "string" }
      },
      "required": ["id", "accessedAt", "username", "accessSuccessful"]
    },
    "CTFWriteup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CTFWriteup",
      "type": "object",
      "description": "Detailed write-up for a CTF challenge.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "competition": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "date": { "type": "string", "format": "date" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "flag": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "competition", "category", "difficulty", "date", "summary", "content"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "projectUrl": { "type": "string", "description": "External link to the project (e.g., GitHub, live demo)." },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description"]
    },
    "Achievement": {
      "title": "Achievement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "platform": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "issuer"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "database": {
    "/users/{ownerId}/secureMessages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/SecureMessage" },
      "description": "Secure messages for the owner."
    },
    "/securePageAccessLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/SecurePageAccessLog" },
      "description": "Logs of access attempts."
    },
    "/ctfWriteups/{writeupId}": {
      "schema": { "$ref": "#/backend/entities/CTFWriteup" },
      "description": "Publicly viewable CTF write-ups."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "Publicly viewable projects."
    },
    "/achievements/{achievementId}": {
      "schema": { "$ref": "#/backend/entities/Achievement" },
      "description": "Publicly viewable achievements."
    }
  }
}
