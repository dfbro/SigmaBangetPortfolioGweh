rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for secure messages. 
     * Visitors can create messages. Reading is allowed for the simulated password-gated dashboard.
     */
    match /users/{ownerId}/secureMessages/{messageId} {
      allow create: if true;
      allow read, list: if true; 
    }

    /**
     * @description Rules for access logs.
     * Anyone can create a log and read them for the simulated dashboard.
     */
    match /securePageAccessLogs/{logId} {
      allow create: if true;
      allow read, list: if true;
    }
  }
}